{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "MasterLabs API",
    "description": "Collection completa da MasterLabs API — SaaS multi-tenant de laudos laboratoriais.\n\n**Como usar:**\n1. Selecione o environment desejado (Local / Stage / Prod)\n2. Execute **Auth > Register Tenant** ou **Auth > Login** — o token é salvo automaticamente\n3. A partir daí todos os endpoints autenticados funcionam sem configuração manual",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{"key": "token","value": "{{token}}","type": "string"}]
  },
  "variable": [
    {"key": "token","value": "","type": "string","description": "JWT token — preenchido automaticamente pelo Login ou Register"},
    {"key": "clientId","value": "","type": "string","description": "ID do último cliente criado — preenchido automaticamente pelo POST /clients"},
    {"key": "attendanceId","value": "","type": "string","description": "ID do último atendimento criado — preenchido automaticamente pelo POST /attendances"},
    {"key": "sampleId","value": "","type": "string","description": "ID da última amostra criada — preenchida automaticamente pelo POST /samples"}
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /healthz",
          "request": {"auth": {"type": "noauth"},"method": "GET","url": {"raw": "{{base_url}}/healthz","host": ["{{base_url}}"],"path": ["healthz"]},"description": "Healthcheck geral da API. Retorna 200 se o servidor está up."},
          "response": []
        },
        {
          "name": "GET /healthz/db",
          "request": {"auth": {"type": "noauth"},"method": "GET","url": {"raw": "{{base_url}}/healthz/db","host": ["{{base_url}}"],"path": ["healthz","db"]},"description": "Healthcheck do banco MySQL. Retorna 200 se a conexão está ativa."},
          "response": []
        }
      ]
    },
    {
      "name": "Tenants",
      "item": [
        {
          "name": "POST /tenants/register",
          "event": [{"listen": "test","script": {"exec": ["if (pm.response.code === 201) {","    const res = pm.response.json();","    if (res.token) {","        pm.collectionVariables.set('token', res.token);","        console.log('Token salvo automaticamente');","    }","}"],"type": "text/javascript"}}],
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"razaoSocial\": \"Laboratório Exemplo S/A\",\n  \"nomeFantasia\": \"Lab Exemplo\",\n  \"cnpj\": \"12345678000195\",\n  \"email\": \"lab@exemplo.com\",\n  \"telefone\": \"11999990000\",\n  \"endereco\": \"Rua das Flores, 123, São Paulo - SP\",\n  \"adminName\": \"Administrador\",\n  \"adminEmail\": \"admin@exemplo.com\",\n  \"adminPassword\": \"senha1234\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/tenants/register","host": ["{{base_url}}"],"path": ["api","v1","tenants","register"]},
            "description": "Cadastra um novo laboratório (tenant) e cria o primeiro usuário ADMIN. Retorna o token JWT automaticamente salvo na collection."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login",
          "event": [{"listen": "test","script": {"exec": ["if (pm.response.code === 200) {","    const res = pm.response.json();","    if (res.token) {","        pm.collectionVariables.set('token', res.token);","        console.log('Token salvo automaticamente');","    }","}"],"type": "text/javascript"}}],
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"email\": \"admin@exemplo.com\",\n  \"password\": \"senha1234\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/auth/login","host": ["{{base_url}}"],"path": ["api","v1","auth","login"]},
            "description": "Autentica um usuário do laboratório. O token JWT é salvo automaticamente na collection."
          },
          "response": []
        },
        {
          "name": "GET /auth/me",
          "request": {"method": "GET","url": {"raw": "{{base_url}}/api/v1/auth/me","host": ["{{base_url}}"],"path": ["api","v1","auth","me"]},"description": "Retorna os dados do usuário autenticado a partir do JWT."},
          "response": []
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "POST /clients — PF",
          "event": [{"listen": "test","script": {"exec": ["if (pm.response.code === 201) {","    const res = pm.response.json();","    if (res.id) {","        pm.collectionVariables.set('clientId', res.id);","        console.log('clientId salvo: ' + res.id);","    }","}"],"type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"tipoPessoa\": \"PF\",\n  \"nome\": \"João da Silva\",\n  \"documento\": \"12345678901\",\n  \"email\": \"joao@email.com\",\n  \"telefone\": \"11999990000\",\n  \"endereco\": \"Rua das Flores, 123, São Paulo - SP\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/clients","host": ["{{base_url}}"],"path": ["api","v1","clients"]},
            "description": "Cria um cliente Pessoa Física (CPF = 11 dígitos). O ID é salvo automaticamente em {{clientId}}.\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "POST /clients — PJ",
          "event": [{"listen": "test","script": {"exec": ["if (pm.response.code === 201) {","    const res = pm.response.json();","    if (res.id) {","        pm.collectionVariables.set('clientId', res.id);","        console.log('clientId salvo: ' + res.id);","    }","}"],"type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"tipoPessoa\": \"PJ\",\n  \"nome\": \"Empresa Exemplo LTDA\",\n  \"documento\": \"12345678000195\",\n  \"email\": \"empresa@exemplo.com\",\n  \"telefone\": \"1133330000\",\n  \"endereco\": \"Av. Paulista, 1000, São Paulo - SP\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/clients","host": ["{{base_url}}"],"path": ["api","v1","clients"]},
            "description": "Cria um cliente Pessoa Jurídica (CNPJ = 14 dígitos). O ID é salvo automaticamente em {{clientId}}.\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "GET /clients",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/clients?page=1&pageSize=20","host": ["{{base_url}}"],"path": ["api","v1","clients"],"query": [{"key": "page","value": "1"},{"key": "pageSize","value": "20"},{"key": "tipoPessoa","value": "PF","disabled": true},{"key": "search","value": "João","disabled": true}]},
            "description": "Lista clientes do laboratório com paginação. Suporta filtro por tipoPessoa e busca por nome/documento.\n\nRoles: ADMIN, ANALYST, VIEWER"
          },
          "response": []
        },
        {
          "name": "GET /clients/:id",
          "request": {"method": "GET","url": {"raw": "{{base_url}}/api/v1/clients/{{clientId}}","host": ["{{base_url}}"],"path": ["api","v1","clients","{{clientId}}"]},"description": "Retorna os detalhes de um cliente pelo ID.\n\nRoles: ADMIN, ANALYST, VIEWER"},
          "response": []
        },
        {
          "name": "PATCH /clients/:id",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"nome\": \"João da Silva Santos\",\n  \"email\": \"joao.novo@email.com\",\n  \"telefone\": \"11988880000\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/clients/{{clientId}}","host": ["{{base_url}}"],"path": ["api","v1","clients","{{clientId}}"]},
            "description": "Atualiza parcialmente um cliente. Apenas os campos enviados são alterados.\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "DELETE /clients/:id",
          "request": {"method": "DELETE","url": {"raw": "{{base_url}}/api/v1/clients/{{clientId}}","host": ["{{base_url}}"],"path": ["api","v1","clients","{{clientId}}"]},"description": "Soft delete do cliente — marca como inativo sem remover do banco. Retorna 204.\n\nRoles: ADMIN apenas"},
          "response": []
        }
      ]
    },
    {
      "name": "Attendances",
      "item": [
        {
          "name": "POST /attendances",
          "event": [{"listen": "test","script": {"exec": ["if (pm.response.code === 201) {","    const res = pm.response.json();","    if (res.id) {","        pm.collectionVariables.set('attendanceId', res.id);","        console.log('attendanceId salvo: ' + res.id);","    }","}"],"type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"clientId\": \"{{clientId}}\",\n  \"tipoColeta\": \"IN_LOCO\",\n  \"descricao\": \"Análise de qualidade da água para fins de consumo humano\",\n  \"dataSolicitacao\": \"2026-05-02T09:00:00.000Z\",\n  \"prazoEntrega\": \"2026-05-10T18:00:00.000Z\",\n  \"responsavel\": \"Dr. Carlos Menezes\",\n  \"observacoes\": \"Urgência nos laudos de coliformes\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/attendances","host": ["{{base_url}}"],"path": ["api","v1","attendances"]},
            "description": "Cria um atendimento (ordem de serviço). Número de protocolo gerado automaticamente. ID salvo em {{attendanceId}}.\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "GET /attendances",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/attendances?page=1&pageSize=20","host": ["{{base_url}}"],"path": ["api","v1","attendances"],"query": [{"key": "page","value": "1"},{"key": "pageSize","value": "20"},{"key": "status","value": "ABERTO","disabled": true},{"key": "tipoColeta","value": "IN_LOCO","disabled": true},{"key": "clientId","value": "{{clientId}}","disabled": true},{"key": "search","value": "","disabled": true}]},
            "description": "Lista atendimentos com paginação. Filtros: status, tipoColeta, clientId, search.\n\nRoles: ADMIN, ANALYST, VIEWER"
          },
          "response": []
        },
        {
          "name": "GET /attendances/:id",
          "request": {"method": "GET","url": {"raw": "{{base_url}}/api/v1/attendances/{{attendanceId}}","host": ["{{base_url}}"],"path": ["api","v1","attendances","{{attendanceId}}"]},"description": "Retorna os detalhes de um atendimento.\n\nRoles: ADMIN, ANALYST, VIEWER"},
          "response": []
        },
        {
          "name": "PATCH /attendances/:id",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"responsavel\": \"Dr. Paulo Lima\",\n  \"observacoes\": \"Prazo antecipado pelo cliente\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/attendances/{{attendanceId}}","host": ["{{base_url}}"],"path": ["api","v1","attendances","{{attendanceId}}"]},
            "description": "Atualiza campos do atendimento parcialmente. Status e número de protocolo são imutáveis aqui.\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "PATCH /attendances/:id/status",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"status\": \"EM_ANDAMENTO\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/attendances/{{attendanceId}}/status","host": ["{{base_url}}"],"path": ["api","v1","attendances","{{attendanceId}}","status"]},
            "description": "Transita o status do atendimento.\nTransições válidas:\n- ABERTO → EM_ANDAMENTO | CANCELADO\n- EM_ANDAMENTO → ENCERRADO | CANCELADO\n- ENCERRADO e CANCELADO são terminais → retorna 422\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "DELETE /attendances/:id",
          "request": {"method": "DELETE","url": {"raw": "{{base_url}}/api/v1/attendances/{{attendanceId}}","host": ["{{base_url}}"],"path": ["api","v1","attendances","{{attendanceId}}"]},"description": "Soft delete do atendimento. Retorna 204.\n\nRoles: ADMIN apenas"},
          "response": []
        }
      ]
    },
    {
      "name": "Samples",
      "item": [
        {
          "name": "POST /samples",
          "event": [{"listen": "test","script": {"exec": ["if (pm.response.code === 201) {","    const res = pm.response.json();","    if (res.id) {","        pm.collectionVariables.set('sampleId', res.id);","        console.log('sampleId salvo: ' + res.id);","    }","}"],"type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"attendanceId\": \"{{attendanceId}}\",\n  \"descricao\": \"Amostra de água superficial\",\n  \"dataColeta\": \"2026-05-01T08:00:00.000Z\",\n  \"dataRecebimento\": \"2026-05-02T09:30:00.000Z\",\n  \"amostrador\": \"Carlos Souza\",\n  \"etiqueta\": \"RIO-001-A\",\n  \"motivo\": \"Monitoramento mensal\",\n  \"temperaturaAmostra\": 18.5,\n  \"temperaturaAmbiente\": 24.0,\n  \"umidadeRelativa\": 72.3,\n  \"pontoColeta\": \"Rio Tietê — km 42\",\n  \"observacoes\": \"Coleta realizada após chuva intensa\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/samples","host": ["{{base_url}}"],"path": ["api","v1","samples"]},
            "description": "Registra uma amostra vinculada a um atendimento. Número sequencial gerado automaticamente. ID salvo em {{sampleId}}.\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "GET /samples",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/samples?page=1&pageSize=20","host": ["{{base_url}}"],"path": ["api","v1","samples"],"query": [{"key": "page","value": "1"},{"key": "pageSize","value": "20"},{"key": "attendanceId","value": "{{attendanceId}}","disabled": true},{"key": "status","value": "RECEBIDA","disabled": true},{"key": "search","value": "","disabled": true}]},
            "description": "Lista amostras com paginação. Filtros: attendanceId, status, search (numeroAmostra, descricao, pontoColeta).\n\nRoles: ADMIN, ANALYST, VIEWER"
          },
          "response": []
        },
        {
          "name": "GET /samples/:id",
          "request": {"method": "GET","url": {"raw": "{{base_url}}/api/v1/samples/{{sampleId}}","host": ["{{base_url}}"],"path": ["api","v1","samples","{{sampleId}}"]},"description": "Retorna os detalhes completos de uma amostra.\n\nRoles: ADMIN, ANALYST, VIEWER"},
          "response": []
        },
        {
          "name": "PATCH /samples/:id",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"amostrador\": \"Paulo Lima\",\n  \"temperaturaAmostra\": 19.2,\n  \"observacoes\": \"Revisado após nova medição\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/samples/{{sampleId}}","host": ["{{base_url}}"],"path": ["api","v1","samples","{{sampleId}}"]},
            "description": "Atualiza campos da amostra parcialmente. Status e número são imutáveis aqui.\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "PATCH /samples/:id/status",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"status\": \"EM_ANALISE\"\n}","options": {"raw": {"language": "json"}}},
            "url": {"raw": "{{base_url}}/api/v1/samples/{{sampleId}}/status","host": ["{{base_url}}"],"path": ["api","v1","samples","{{sampleId}}","status"]},
            "description": "Transita o status da amostra.\nTransições válidas:\n- RECEBIDA → EM_ANALISE | CANCELADA | REJEITADA\n- EM_ANALISE → CONCLUIDA | CANCELADA | REJEITADA\n- CONCLUIDA, CANCELADA e REJEITADA são terminais → retorna 422\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "DELETE /samples/:id",
          "request": {"method": "DELETE","url": {"raw": "{{base_url}}/api/v1/samples/{{sampleId}}","host": ["{{base_url}}"],"path": ["api","v1","samples","{{sampleId}}"]},"description": "Soft delete da amostra. Retorna 204.\n\nRoles: ADMIN apenas"},
          "response": []
        }
      ]
    }
  ]
}
