{
  "name": "masterlabs-api",
  "version": "1.0.0",
  "description": "MasterLabs API - Node.js + Express",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/integration/**/*.test.js"],
    "setupFiles": ["./tests/setup.js"]
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2"
  }
}
