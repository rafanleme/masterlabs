                  "        pm.collectionVariables.set('clientId', res.id);",
                  "        console.log('clientId salvo: ' + res.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoPessoa\": \"PJ\",\n  \"nome\": \"Empresa Exemplo LTDA\",\n  \"documento\": \"12345678000195\",\n  \"email\": \"empresa@exemplo.com\",\n  \"telefone\": \"1133330000\",\n  \"endereco\": \"Av. Paulista, 1000, São Paulo - SP\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/clients",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clients"]
            },
            "description": "Cria um cliente Pessoa Jurídica (CNPJ = 14 dígitos). O ID é salvo automaticamente em {{clientId}}.\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "GET /clients",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/clients?page=1&pageSize=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clients"],
              "query": [
                { "key": "page", "value": "1", "description": "Página (default: 1)" },
                { "key": "pageSize", "value": "20", "description": "Itens por página (default: 20, max: 100)" },
                { "key": "tipoPessoa", "value": "PF", "description": "Filtrar por tipo: PF ou PJ", "disabled": true },
                { "key": "search", "value": "João", "description": "Buscar por nome ou documento", "disabled": true }
              ]
            },
            "description": "Lista clientes do laboratório com paginação. Suporta filtro por tipoPessoa e busca por nome/documento.\n\nRoles: ADMIN, ANALYST, VIEWER"
          },
          "response": []
        },
        {
          "name": "GET /clients/:id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/clients/{{clientId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clients", "{{clientId}}"]
            },
            "description": "Retorna os detalhes de um cliente pelo ID. Usa {{clientId}} salvo automaticamente pelo POST.\n\nRoles: ADMIN, ANALYST, VIEWER"
          },
          "response": []
        },
        {
          "name": "PATCH /clients/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João da Silva Santos\",\n  \"email\": \"joao.novo@email.com\",\n  \"telefone\": \"11988880000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/clients/{{clientId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clients", "{{clientId}}"]
            },
            "description": "Atualiza parcialmente um cliente. Apenas os campos enviados são alterados.\n\nRoles: ADMIN, ANALYST"
          },
          "response": []
        },
        {
          "name": "DELETE /clients/:id",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/clients/{{clientId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clients", "{{clientId}}"]
            },
            "description": "Soft delete do cliente — marca como inativo sem remover do banco. Retorna 204.\n\nRoles: ADMIN apenas"
          },
          "response": []
        }
      ]
    }
  ]
}
